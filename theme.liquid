<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#0D0D0D">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{%- unless page_title contains shop.name %} — {{ shop.name }}{%- endunless -%}</title>
  {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}

  {{ content_for_header }}
  {{ 'takl.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}{% if template.suffix %}-{{ template.suffix }}{% endif %}">
  <a class="skip-link" href="#main">Skip to content</a>

  <!-- Cursor -->
  <div id="t-cursor" aria-hidden="true"></div>
  <div id="t-cursor-ring" aria-hidden="true"></div>

  <!-- Overlay -->
  <div class="t-overlay" id="t-overlay" aria-hidden="true"></div>

  <!-- Cart Drawer -->
  <div class="t-drawer" id="t-cart-drawer" role="dialog" aria-label="Cart" aria-modal="true">
    <div class="t-drawer__head">
      <span class="t-drawer__title">Your Bag (<span class="t-cart-count">0</span>)</span>
      <button class="t-drawer__close" aria-label="Close cart">&#x2715;</button>
    </div>
    <div class="cart-drawer__body" id="cart-drawer-body">
      <div class="cart-drawer__empty">
        <p>Your bag is empty.</p>
        <a href="/collections" class="btn-outline" style="display:inline-flex">Shop the Drop →</a>
      </div>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-subtotal">
        <span>Subtotal</span>
        <strong id="cart-subtotal">$0.00</strong>
      </div>
      <a href="/cart" class="btn-pine">Checkout →</a>
      <p class="cart-note">Shipping & taxes calculated at checkout</p>
    </div>
  </div>

  <!-- Nav Drawer -->
  <nav class="t-drawer" id="t-nav-drawer" aria-label="Navigation">
    <div class="t-drawer__head">
      <span class="t-drawer__title" style="font-size:1.2rem;font-weight:800;letter-spacing:.2em">TAKL</span>
      <button class="t-drawer__close" aria-label="Close navigation">&#x2715;</button>
    </div>
    <div class="nav-drawer__links">
      {%- for link in linklists.main-menu.links -%}
        <a class="nav-drawer__link" href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </div>
    <div class="nav-drawer__sub">
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}">Account</a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}">Cart</a>
    </div>
  </nav>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <script src="{{ 'takl.js' | asset_url }}" defer></script>
</body>
</html>
