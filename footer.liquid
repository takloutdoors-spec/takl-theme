<footer class="t-footer" role="contentinfo">
  <div class="t-footer__top">
    <div>
      <a href="{{ routes.root_url }}" class="t-footer__brand">TAKL</a>
      <p class="t-footer__tagline">{{ section.settings.tagline }}</p>
      <div class="t-footer__social">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener">Instagram</a>
        {%- endif -%}
        {%- if section.settings.tiktok != blank -%}
          <a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener">TikTok</a>
        {%- endif -%}
        {%- if section.settings.twitter != blank -%}
          <a href="{{ section.settings.twitter }}" target="_blank" rel="noopener">X</a>
        {%- endif -%}
      </div>
    </div>

    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        <span class="t-footer__col-title">{{ block.settings.title }}</span>
        <ul class="t-footer__links">
          {%- for link in linklists[block.settings.menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endfor -%}
  </div>

  <div class="t-footer__bottom">
    <p class="t-footer__copy">&copy; {{ 'now' | date: '%Y' }} TAKL. All rights reserved.</p>
    <div class="t-footer__legal">
      <a href="/policies/privacy-policy">Privacy</a>
      <a href="/policies/terms-of-service">Terms</a>
      <a href="/policies/refund-policy">Returns</a>
    </div>
  </div>
</footer>

{% schema %}
{ "name": "Footer", "limit": 1,
  "blocks": [{ "type": "col", "name": "Link Column", "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Shop" },
    { "type": "link_list", "id": "menu", "label": "Menu" }
  ]}],
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Limited drops. No restocks. Live Different." },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "twitter", "label": "X / Twitter URL" }
  ],
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "col", "settings": { "title": "Shop" } },
      { "type": "col", "settings": { "title": "Info" } },
      { "type": "col", "settings": { "title": "Help" } }
    ]
  }]
}
{% endschema %}
