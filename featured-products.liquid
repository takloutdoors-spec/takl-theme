<section class="t-products">
  <div class="t-products__head reveal">
    <div>
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="t-products__title" style="color:var(--white)">{{ section.settings.title }}</h2>
    </div>
    {%- if section.settings.collection != blank -%}
      <a href="{{ collections[section.settings.collection].url }}" class="t-products__view">View All →</a>
    {%- endif -%}
  </div>

  <div class="t-products__grid{% if section.settings.layout == 'wide' %} t-products__grid--wide{% endif %}">
    {%- liquid
      if section.settings.collection != blank
        assign prod_list = collections[section.settings.collection].products
      else
        assign prod_list = section.blocks | map: 'settings'
      endif
    -%}

    {%- for product in prod_list limit: section.settings.count -%}
      {%- render 'product-card', product: product, index: forloop.index -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{ "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Drop" },
    { "type": "text", "id": "title", "label": "Title", "default": "Memories Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "min": 2, "max": 8, "step": 1, "default": 4, "label": "Number of products" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [{ "value": "grid", "label": "Even grid" },{ "value": "wide", "label": "Wide first" }], "default": "grid" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
