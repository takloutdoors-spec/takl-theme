<section class="takl-products" aria-labelledby="featured-products-title">

  <div class="takl-section-header takl-reveal">
    <div>
      <span class="takl-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="takl-section-title" id="featured-products-title">{{ section.settings.title }}</h2>
    </div>
    {%- if section.settings.view_all_label != blank -%}
      <a href="{{ section.settings.view_all_url }}" class="btn-ghost-dark">
        {{ section.settings.view_all_label }} →
      </a>
    {%- endif -%}
  </div>

  <div class="takl-products__grid">
    {%- if section.settings.collection != blank -%}
      {%- assign featured_collection = collections[section.settings.collection] -%}
      {%- assign product_limit = section.settings.product_count | default: 5 -%}

      {%- for product in featured_collection.products limit: product_limit -%}
        {%- liquid
          if forloop.first
            assign badge = 'New'
          elsif product.metafields.custom.badge != blank
            assign badge = product.metafields.custom.badge
          else
            assign badge = ''
          endif
        -%}
        {% render 'product-card', product: product, badge: badge, index: forloop.index %}
      {%- endfor -%}

    {%- else -%}
      {%- comment -%} Fallback: show blocks if no collection is selected {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- assign product = all_products[block.settings.product] -%}
          {%- if product != blank -%}
            {% render 'product-card', product: product, badge: block.settings.badge, index: forloop.index %}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select a collection to automatically populate products"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5,
      "label": "Number of products"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product (manual)",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "New"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Featured Products" }
  ]
}
{% endschema %}
