<header class="t-header" id="t-header" role="banner">
  <div class="t-header__inner">
    <a href="{{ routes.root_url }}" class="t-header__logo" aria-label="{{ shop.name }}">TAKL</a>

    <nav class="t-header__nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="t-header__actions">
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="t-header__action">Account</a>
      {%- endif -%}
      <button class="t-header__action t-cart-action" id="t-cart-toggle" aria-label="Open cart">
        Bag
        <span class="t-cart-count" aria-live="polite" style="display:none">0</span>
      </button>
      <button class="t-header__burger" id="t-burger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{ "name": "Header", "limit": 1,
  "settings": [
    { "type": "link_list", "id": "menu", "default": "main-menu", "label": "Navigation menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
