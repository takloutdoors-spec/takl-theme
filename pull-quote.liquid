<section class="takl-quote" aria-label="Quote">
  <div class="takl-quote__inner takl-reveal">
    <div class="takl-quote__rule" aria-hidden="true"></div>
    <blockquote class="takl-quote__text">
      {{ section.settings.quote }}
    </blockquote>
    {%- if section.settings.attribution != blank -%}
      <p class="takl-quote__attribution">— {{ section.settings.attribution }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Pull Quote",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote text",
      "default": "There is no conflict between the mountain and the marina. TAKL was built on that belief."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution",
      "default": "Thomas Alcott, Founder & Creative Director"
    }
  ],
  "presets": [
    { "name": "Pull Quote" }
  ]
}
{% endschema %}
