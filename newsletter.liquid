<section class="takl-newsletter" aria-labelledby="newsletter-title">
  <div class="takl-newsletter__inner">

    <div class="takl-reveal">
      <span class="takl-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="takl-newsletter__title" id="newsletter-title">
        {{ section.settings.title }}
      </h2>
      <p class="takl-newsletter__body">{{ section.settings.body }}</p>
    </div>

    <div class="takl-reveal takl-reveal--d1">
      {%- form 'customer', id: 'newsletter-form', class: 'takl-newsletter__form takl-newsletter__form-el' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="takl-newsletter__row">
          <label for="newsletter-email" class="visually-hidden">Email address</label>
          <input
            type="email"
            name="contact[email]"
            id="newsletter-email"
            class="takl-newsletter__input"
            value="{{ form.email }}"
            placeholder="{{ section.settings.input_placeholder }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            required
            aria-required="true"
          >
          <button type="submit" class="takl-newsletter__submit">
            {{ section.settings.button_label }}
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="takl-newsletter__note" style="color: #4A5C3F;">
            {{ 'newsletter.success' | t | default: 'Thank you for joining.' }}
          </p>
        {%- elsif form.errors -%}
          <p class="takl-newsletter__note" style="color: #9B4A1E;">
            {{ form.errors.translated_fields['email'] | capitalize }}
            {{ form.errors.messages['email'] }}
          </p>
        {%- else -%}
          <p class="takl-newsletter__note">{{ section.settings.note }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>

  </div>
</section>

<style>
  .visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Inner Circle"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "First access.\nAlways.",
      "info": "Wrap words in <em></em> for italic"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Limited drops, private events, and early access to new collections — sent only to those who know what to look for."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Fine print",
      "default": "Private and unobtrusive. Unsubscribe anytime."
    }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
