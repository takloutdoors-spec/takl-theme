<section class="t-newsletter">
  <div class="t-newsletter__inner reveal">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="t-newsletter__title">{{ section.settings.title }}</h2>
    <p class="t-newsletter__body">{{ section.settings.body }}</p>

    {%- form 'customer', id: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter,takl-inner-circle">
      <div class="t-newsletter__form">
        <label for="nl-email" class="visually-hidden">Email address</label>
        <input type="email" id="nl-email" name="contact[email]" class="t-newsletter__input"
               placeholder="{{ section.settings.placeholder }}" autocomplete="email" required>
        <button type="submit" class="t-newsletter__submit">{{ section.settings.button }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="t-newsletter__note" style="color:var(--pine-mid)">You're in. Watch your inbox.</p>
      {%- elsif form.errors -%}
        <p class="t-newsletter__note" style="color:var(--clay)">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
      {%- else -%}
        <p class="t-newsletter__note">{{ section.settings.note }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{ "name": "Newsletter", "limit": 1,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "First Access" },
    { "type": "text", "id": "title", "label": "Title", "default": "Get Drop Alerts Before Anyone Else." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Limited drops sell out fast. Get on the list for early access, exclusive previews, and drops you won't see anywhere else." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email" },
    { "type": "text", "id": "button", "label": "Button label", "default": "I'm In" },
    { "type": "text", "id": "note", "label": "Fine print", "default": "No spam. Unsubscribe any time." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
