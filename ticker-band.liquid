<div class="t-ticker" aria-hidden="true">
  <div class="t-ticker__inner">
    {%- for i in (1..3) -%}
      {%- for block in section.blocks -%}
        <span class="t-ticker__item">{{ block.settings.text }}<span class="t-ticker__dot"></span></span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{ "name": "Ticker Band", "max_blocks": 8,
  "blocks": [{ "type": "item", "name": "Item", "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Live Different" }] }],
  "presets": [{
    "name": "Ticker Band",
    "blocks": [
      { "type": "item", "settings": { "text": "Live Different" } },
      { "type": "item", "settings": { "text": "Limited Drop" } },
      { "type": "item", "settings": { "text": "No Restock" } },
      { "type": "item", "settings": { "text": "Memories Collection" } },
      { "type": "item", "settings": { "text": "TAKL SS 2026" } },
      { "type": "item", "settings": { "text": "Free Shipping $150+" } }
    ]
  }]
}
{% endschema %}
