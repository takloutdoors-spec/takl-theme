{%- liquid
  assign first_variant = product.first_available_variant | default: product.variants.first
  assign is_sold_out = false
  unless product.available
    assign is_sold_out = true
  endunless
-%}

<article class="t-card reveal reveal-d{{ index | modulo: 4 | plus: 1 }}">
  <a href="{{ product.url }}">
    <div class="t-card__media">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 800
           | image_tag: loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
      {%- else -%}
        <div style="width:100%;height:100%;background:#1a1a1a;"></div>
      {%- endif -%}

      {%- if is_sold_out -%}
        <span class="t-card__badge t-card__badge--sold">Sold Out</span>
      {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
        <span class="t-card__badge t-card__badge--new">New</span>
      {%- elsif product.tags contains 'limited' or product.tags contains 'Limited' -%}
        <span class="t-card__badge t-card__badge--limited">Limited</span>
      {%- endif -%}

      {%- unless is_sold_out -%}
        <button class="t-card__quick" data-variant="{{ first_variant.id }}" aria-label="Quick add {{ product.title }}">
          Quick Add
        </button>
      {%- endunless -%}
    </div>

    <div class="t-card__info">
      <p class="t-card__name">{{ product.title }}</p>
      <p class="t-card__meta">{{ product.type }}{% if product.variants.size > 1 %} · {{ product.variants.size }} options{% endif %}</p>
      <div class="t-card__bottom">
        <span class="t-card__price">
          {%- if is_sold_out -%}
            Sold Out
          {%- else -%}
            {{ product.price | money }}
          {%- endif -%}
        </span>
        {%- if product.options_with_values.first.name == 'Color' -%}
          <div class="t-card__swatches" aria-hidden="true">
            {%- for value in product.options_with_values.first.values limit: 4 -%}
              <span class="t-card__swatch" style="background:{{ value | handleize }};"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </a>
</article>
