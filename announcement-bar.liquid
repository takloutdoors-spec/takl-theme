{%- if section.settings.show -%}
<div class="t-announce">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {%- else -%}
    {{ section.settings.text }}
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{ "name": "Announcement Bar", "limit": 1,
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show bar", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "The Memories Drop — Friday 12PM EST — Limited Quantities" },
    { "type": "url", "id": "link", "label": "Link (optional)" }
  ],
  "presets": [{ "name": "Announcement Bar" }]
}
{% endschema %}
