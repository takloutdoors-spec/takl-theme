<section class="t-hero" aria-label="Hero">
  <div class="t-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400
         | image_tag: loading: 'eager', fetchpriority: 'high', alt: section.settings.image.alt | default: shop.name }}
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#2D4A3E 0%,#0D0D0D 60%,#C4714A 100%);"></div>
    {%- endif -%}
  </div>

  <div class="t-hero__content">
    <span class="t-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 class="t-hero__title">{{ section.settings.title }}</h1>
    <p class="t-hero__body">{{ section.settings.body }}</p>
    <div class="t-hero__cta">
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn-primary">
          {{ section.settings.cta_label }} <span class="arr">→</span>
        </a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a href="{{ section.settings.cta2_url }}" class="btn-outline">{{ section.settings.cta2_label }}</a>
      {%- endif -%}
    </div>
  </div>

  <div class="t-hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="t-hero__scroll-line"></div>
  </div>
</section>

{% schema %}
{ "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SS 2026 — The Memories Drop" },
    { "type": "textarea", "id": "title", "label": "Headline", "default": "LIVE\nDIFFERENT." },
    { "type": "textarea", "id": "body", "label": "Subheading", "default": "Limited drops for the people who ski hard, fish harder, and never miss a good night out." },
    { "type": "text", "id": "cta_label", "label": "Primary CTA", "default": "Shop the Drop" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA", "default": "Our Story" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
